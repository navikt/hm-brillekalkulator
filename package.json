{
  "name": "hm-brillekalkulator",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^7.0.3",
    "prettier": "^3.8.4"
  },
  "scripts": {
    "postinstall": "pnpm --prefix client install && go install -C server ./...",
    "dev": "pnpm run --prefix client dev",
    "test:client": "pnpm run --prefix client test",
    "test:server": "go test -C server ./...",
    "test": "pnpm run test:client && pnpm run test:server",
    "build:client": "pnpm run --prefix client build",
    "build:server": "go build -C server ./...",
    "build": "pnpm run build:client && pnpm run build:server",
    "clean:client": "pnpm run --prefix client clean",
    "clean:server": "go clean -C server",
    "clean": "pnpm run clean:client && pnpm run clean:server"
  }
}
